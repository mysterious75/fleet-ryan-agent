# Fleet-Ryan Environment Configuration
# Copy this to .env and fill in your values

# ========== Application ==========
APP_NAME=Fleet-Ryan API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ========== Database ==========
DATABASE_URL=postgresql+asyncpg://fleetryan:fleetryan123@postgres:5432/fleetryan
DB_PASSWORD=fleetryan123

# ========== Redis ==========
REDIS_URL=redis://redis:6379/0

# ========== Fleet APIs ==========
# Samsara API (Primary fleet platform)
SAMSARA_API_TOKEN=your_samsara_api_token_here

# Motive API (Secondary fleet platform)
MOTIVE_API_KEY=your_motive_api_key_here

# Fleetio API (Maintenance management)
FLEETIO_API_TOKEN=your_fleetio_api_token_here
FLEETIO_ACCOUNT_TOKEN=your_fleetio_account_token_here

# ========== Telegram Bot ==========
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
FLEET_MANAGER_CHAT_ID=your_chat_id_here

# ========== Security ==========
SECRET_KEY=change-me-to-a-random-string-in-production
API_KEY=your_api_key_here

# ========== Rate Limiting ==========
RATE_LIMIT_PER_MINUTE=60

# ========== Monitoring ==========
HEARTBEAT_INTERVAL_SECONDS=1800
